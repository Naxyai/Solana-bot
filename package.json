{
  "name": "solana-arb-bot",
  "version": "2.0.0",
  "description": "High-frequency Solana arbitrage bot with Jito bundles, Jupiter routing, and real-time dashboard",
  "main": "bot/index.js",
  "scripts": {
    "start": "node bot/index.js",
    "dev": "node --watch bot/index.js",
    "devnet": "NETWORK=devnet node bot/index.js",
    "dashboard": "node dashboard/server.js",
    "start:all": "concurrently \"npm run start\" \"npm run dashboard\"",
    "test": "node scripts/test-connection.js",
    "check-balance": "node scripts/check-balance.js",
    "simulate": "DRY_RUN=true node bot/index.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@jito-foundation/mev-sdk": "^0.1.3",
    "@orca-so/whirlpools-sdk": "^0.13.7",
    "@project-serum/anchor": "^0.26.0",
    "@raydium-io/raydium-sdk-v2": "^0.1.55",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.2",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
